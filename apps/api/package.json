{
  "name": "@pdv/api",
  "version": "0.1.0",
  "private": true,
  "description": "API de coordinación de emergencias (Fastify + PostgreSQL)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "seed:demo": "tsx src/seed-demo.ts",
    "seed:orgs": "tsx src/seed-orgs.ts",
    "sim": "tsx src/simulate.ts",
    "ingest": "tsx src/ingest.ts",
    "ingest:loop": "tsx src/ingest.ts --interval 30",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx ./test"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^11.1.0",
    "fastify": "^5.2.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
