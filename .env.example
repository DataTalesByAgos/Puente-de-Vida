# ──────────────────────────────────────────────────────────────
# Puente de Vida — variables de entorno (copiar a .env)
# ──────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=pdv
POSTGRES_PASSWORD=pdv_dev_password
POSTGRES_DB=puente_de_vida
POSTGRES_PORT=5432

# Cadena de conexión que usa la API.
# Dentro de Docker el host es "db"; en local usar "localhost".
DATABASE_URL=postgres://pdv:pdv_dev_password@db:5432/puente_de_vida

# API
API_PORT=4000
# Coma-separado. Origen del front para CORS.
CORS_ORIGIN=http://localhost:3000

# Web (Vite) — URL pública de la API consumida por el navegador
VITE_API_URL=http://localhost:4000
WEB_PORT=3000

# IA (opcional). Por defecto usa clasificador heurístico local
# (cero costo, funciona offline). Para usar un LLM:
#   AI_PROVIDER=openai
#   AI_API_KEY=sk-...
#   AI_API_URL=https://api.openai.com/v1
#   AI_MODEL=gpt-4o-mini
#
# OpenAI-compatible: funciona con OpenAI, Anthropic (OpenAI-compatible endpoint),
# Ollama, vLLM, Together, Azure OpenAI, etc.
AI_PROVIDER=none
AI_API_KEY=
AI_API_URL=
AI_MODEL=gpt-4o-mini

# WhatsApp (opcional). Proveedor genérico de WhatsApp Business API.
# Compatible con Kapso, Meta Cloud API, 360dialog, WATI, Twilio, etc.
# WHATSAPP_API_URL=https://api.kapso.ai/v1/whatsapp/messages     # Kapso
# WHATSAPP_API_URL=https://graph.facebook.com/v21.0/{phone_id}/messages  # Meta Cloud API
# WHATSAPP_API_URL=https://waba.360dialog.io/v1/messages          # 360dialog
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_AUTO_REPLY=true

# Admin panel (login)
ADMIN_USER=admin
ADMIN_PASS=PdV2026!
ADMIN_ROLE=admin
